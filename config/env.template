# Copy to ~/.hermes/.env and fill in your values

# Search backends
# SEARXNG_URL is auto-set in docker-compose.yml — no need to set here
# Uncomment one of the following if you want to use a different search backend:
# SEARXNG_URL=http://searxng-core:8080
# FIRECRAWL_API_KEY=fc-your-key
# BRAVE_SEARCH_API_KEY=BS-your-key
# TAVILY_API_KEY=tvly-your-key
# EXA_API_KEY=your-key
# PARALLEL_API_KEY=your-key

# Required for Hermes in Docker
HERMES_HOME=/opt/data
